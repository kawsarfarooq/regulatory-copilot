NODE_ENV=production
URL=http://localhost:3000
PORT=3000
WEB_CONCURRENCY=1

SECRET_KEY=__SECRET_KEY__
UTILS_SECRET=__UTILS_SECRET__

DATABASE_URL=postgres://outline:__POSTGRES_PASSWORD__@postgres:5432/outline
PGSSLMODE=disable
REDIS_URL=redis://redis:6379

FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
FILE_STORAGE_UPLOAD_MAX_SIZE=262144000

FORCE_HTTPS=false

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=Outline <noreply@local.test>
SMTP_REPLY_EMAIL=noreply@local.test
SMTP_SECURE=false

DEFAULT_LANGUAGE=en_US
ENABLE_UPDATES=false
LOG_LEVEL=info
